{
  "description": "Color Toggle",
  "manifest_version": 2,
  "name": "Color Toggle",
  "version": "1.0",

  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "browserSettings"
  ],
  "browser_action": {
    "default_icon": {
      "32": "icons/color-smiley-32.png",
      "48": "icons/color-smiley48.png"
    }
  }
}
